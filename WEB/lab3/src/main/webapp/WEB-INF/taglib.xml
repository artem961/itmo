<?xml version="1.0" encoding="UTF-8"?>
<facelet-taglib
        xmlns="http://xmlns.jcp.org/xml/ns/javaee"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
    http://xmlns.jcp.org/xml/ns/javaee/web-facelettaglibrary_2_2.xsd"
        version="2.2">

    <namespace>http://taglib/components</namespace>

    <tag>
        <tag-name>accordion</tag-name>
        <component>
            <component-type>accordionTag</component-type>
        </component>
        <attribute>
            <name>mode</name>
            <required>true</required>
            <type>java.lang.String</type>
        </attribute>
        <attribute>
            <name>expanded</name>
            <required>false</required>
            <type>java.lang.String</type>
        </attribute>
    </tag>

    <tag>
        <tag-name>section</tag-name>
        <component>
            <component-type>accordionSection</component-type>
        </component>
        <attribute>
            <name>title</name>
            <required>true</required>
            <type>java.lang.String</type>
        </attribute>
    </tag>
</facelet-taglib>