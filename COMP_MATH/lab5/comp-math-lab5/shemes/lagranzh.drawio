          <mxGeometry x="302" y="850" width="196" height="72" as="geometry" />
        </mxCell>
        <mxCell id="calc_terms" value="numerator = x - points&lt;sub&gt;j&lt;/sub&gt;.x&lt;br&gt;denominator = points&lt;sub&gt;i&lt;/sub&gt;.x - points&lt;sub&gt;j&lt;/sub&gt;.x&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="226.25" y="982" width="347.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="check_zero" value="denominator == 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
