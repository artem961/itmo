          <mxGeometry x="90" y="1520" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="calc_li" value="li = (li * numerator) / denominator" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="465" y="1264" width="235" height="56" as="geometry" />
        </mxCell>
        <mxCell id="calc_res" value="res = res + points&lt;sub&gt;i&lt;/sub&gt;.y * li" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
