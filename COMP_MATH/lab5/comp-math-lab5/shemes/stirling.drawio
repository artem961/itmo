        <mxCell id="edge_2" value="Да" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;exitX=0.5;exitY=1;" parent="1" source="check_n" target="err_n" edge="1">
          <mxGeometry relative="1" as="geometry" />
