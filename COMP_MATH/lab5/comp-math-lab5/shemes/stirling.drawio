<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.0.16 Chrome/132.0.6834.196 Electron/34.2.0 Safari/537.36" version="26.0.16">
  <diagram id="scheme-gen" name="StirlingInterpolation">
    <mxGraphModel dx="4052" dy="1553" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start_node" value="НАЧАЛО" style="ellipse;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="100" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="input_data" value="points, x" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="220" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_n" value="n &lt; 3 OR n % 2 == 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="272.25" y="340" width="255.49999999999997" height="72" as="geometry" />
        </mxCell>
        <mxCell id="err_n" value="Exception" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="66.25" y="472" width="407.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_eq" value="checkEquidistant(points)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="513.75" y="472" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pre_vars" value="n = points.size&lt;br&gt;h = points&lt;sub&gt;1&lt;/sub&gt;.x - points&lt;sub&gt;0&lt;/sub&gt;.x&lt;br&gt;centerIdx = n / 2&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="263.75" y="592" width="272.5" height="110" as="geometry" />
        </mxCell>
        <mxCell id="calc_diffs" value="diffs = calculateFiniteDifferences(points)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="222.5" y="762" width="355" height="60" as="geometry" />
        </mxCell>
        <mxCell id="init_base" value="x0 = points&lt;sub&gt;centerIdx&lt;/sub&gt;.x&lt;br&gt;t = (x - x0) / h&lt;br&gt;res = diffs&lt;sub&gt;0&lt;/sub&gt;&lt;sub&gt;centerIdx&lt;/sub&gt;&lt;br&gt;firstAvgDelta = (diffs&lt;sub&gt;1&lt;/sub&gt;&lt;sub&gt;centerIdx - 1&lt;/sub&gt; + diffs&lt;sub&gt;1&lt;/sub&gt;&lt;sub&gt;centerIdx&lt;/sub&gt;) / 2&lt;br&gt;res = res + t * firstAvgDelta&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="196.88" y="882" width="406.25" height="128" as="geometry" />
        </mxCell>
        <mxCell id="loop_k" value="k = 2, n - 1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="316" y="1092" width="168" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_even" value="k % 2 == 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="302" y="1212" width="196" height="72" as="geometry" />
        </mxCell>
        <mxCell id="calc_even" value="m = k / 2&lt;br&gt;deltaY = diffs&lt;sub&gt;k&lt;/sub&gt;&lt;sub&gt;centerIdx - m&lt;/sub&gt;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-57.5" y="1344" width="295" height="90" as="geometry" />
        </mxCell>
        <mxCell id="calc_odd" value="m = (k - 1) / 2&lt;br&gt;deltaY = (diffs&lt;sub&gt;k&lt;/sub&gt;&lt;sub&gt;centerIdx - m - 1&lt;/sub&gt; + diffs&lt;sub&gt;k&lt;/sub&gt;&lt;sub&gt;centerIdx - m&lt;/sub&gt;) / 2&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="316" y="1344" width="437.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="calc_funcs" value="term = stirlingTerm(t, k)&lt;br&gt;fact = factorial(k)&lt;br&gt;" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="286.25" y="1494" width="227.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="update_res" value="res = res + (term * deltaY) / fact" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="252.5" y="1644" width="295" height="60" as="geometry" />
        </mxCell>
        <mxCell id="out_res" value="res" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="1764" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="end_node" value="КОНЕЦ" style="ellipse;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="1884" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="edge_0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;exitX=0.5;exitY=1;" parent="1" source="start_node" target="input_data" edge="1">
          <mxGeometry relative="1" as="geometry" />
