<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.0.16 Chrome/132.0.6834.196 Electron/34.2.0 Safari/537.36" version="26.0.16">
  <diagram id="scheme-gen" name="NewtonInterpolation">
    <mxGraphModel dx="1843" dy="887" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start_node" value="НАЧАЛО" style="ellipse;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="100" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="input_data" value="points, x" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="220" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_eq" value="checkEquidistant(points)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="290" y="340" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pre_vars" value="n = points.size&lt;br&gt;h = points&lt;sub&gt;1&lt;/sub&gt;.x - points&lt;sub&gt;0&lt;/sub&gt;.x&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="263.75" y="460" width="272.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="calc_diffs" value="diffs = calculateFiniteDifferences(points)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="222.5" y="610" width="355" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_fwd" value="abs(x - points&lt;sub&gt;0&lt;/sub&gt;.x) &lt;= abs(x - points&lt;sub&gt;n-1&lt;/sub&gt;.x)" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="120" y="730" width="560" height="72" as="geometry" />
        </mxCell>
        <mxCell id="init_fwd" value="useFwd = true&lt;br&gt;tCalc = (x - points&lt;sub&gt;0&lt;/sub&gt;.x) / h&lt;br&gt;res = points&lt;sub&gt;0&lt;/sub&gt;.y&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="107.5" y="862" width="265" height="110" as="geometry" />
        </mxCell>
        <mxCell id="init_bwd" value="useFwd = false&lt;br&gt;tCalc = (x - points&lt;sub&gt;n-1&lt;/sub&gt;.x) / h&lt;br&gt;res = points&lt;sub&gt;n-1&lt;/sub&gt;.y&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="412.5" y="862" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="init_term" value="termCalc = 1" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="1032" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="loop_k" value="k = 1, n - 1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="316" y="1152" width="168" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_loop_fwd" value="useFwd == true" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="298.5" y="1272" width="203" height="72" as="geometry" />
        </mxCell>
        <mxCell id="loop_fwd_vars" value="delta = tCalc - (k - 1)&lt;br&gt;deltaY = diffs&lt;sub&gt;k&lt;/sub&gt;&lt;sub&gt;0&lt;/sub&gt;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="141.25" y="1404" width="212.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="loop_bwd_vars" value="delta = tCalc + (k - 1)&lt;br&gt;deltaY = diffs&lt;sub&gt;k&lt;/sub&gt;&lt;sub&gt;n - 1 - k&lt;/sub&gt;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="393.75" y="1404" width="265" height="90" as="geometry" />
        </mxCell>
        <mxCell id="calc_fact" value="fact = factorial(k)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="308.75" y="1554" width="182.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="calc_term_res" value="termCalc = termCalc * delta&lt;br&gt;res = res + (termCalc * deltaY) / fact&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="237.5" y="1674" width="325" height="90" as="geometry" />
        </mxCell>
        <mxCell id="out_res" value="res" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="1824" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="end_node" value="КОНЕЦ" style="ellipse;whiteSpace=wrap;html=1;" parent="1" vertex="1">
