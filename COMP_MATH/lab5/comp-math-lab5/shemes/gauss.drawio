<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.0.16 Chrome/132.0.6834.196 Electron/34.2.0 Safari/537.36" version="26.0.16">
  <diagram id="scheme-gen" name="GaussInterpolation">
    <mxGraphModel dx="5127" dy="2070" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start_node" value="НАЧАЛО" style="ellipse;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="100" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="input_data" value="points, x" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="220" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_n" value="n &lt; 3 OR n % 2 == 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="272.25" y="340" width="255.49999999999997" height="72" as="geometry" />
        </mxCell>
        <mxCell id="err_n" value="Exception" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="66.25" y="472" width="407.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_eq" value="checkEquidistant(points)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="513.75" y="472" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pre_vars" value="n = points.size&lt;br&gt;h = points&lt;sub&gt;1&lt;/sub&gt;.x - points&lt;sub&gt;0&lt;/sub&gt;.x&lt;br&gt;centerIdx = n / 2&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="263.75" y="592" width="272.5" height="110" as="geometry" />
        </mxCell>
        <mxCell id="calc_diffs" value="diffs = calculateFiniteDifferences(points)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="222.5" y="762" width="355" height="60" as="geometry" />
        </mxCell>
        <mxCell id="init_vars" value="x0 = points&lt;sub&gt;centerIdx&lt;/sub&gt;.x&lt;br&gt;t = (x - x0) / h&lt;br&gt;res = diffs&lt;sub&gt;0&lt;/sub&gt;&lt;sub&gt;centerIdx&lt;/sub&gt;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="278.75" y="882" width="242.5" height="110" as="geometry" />
        </mxCell>
        <mxCell id="check_fwd_base" value="t &gt;= 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="302" y="1052" width="196" height="72" as="geometry" />
        </mxCell>
        <mxCell id="init_fwd" value="useForward = true&lt;br&gt;firstDeltaY = diffs&lt;sub&gt;1&lt;/sub&gt;&lt;sub&gt;centerIdx&lt;/sub&gt;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="62.5" y="1184" width="302.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="init_bwd" value="useForward = false&lt;br&gt;firstDeltaY = diffs&lt;sub&gt;1&lt;/sub&gt;&lt;sub&gt;centerIdx - 1&lt;/sub&gt;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="405" y="1184" width="332.5" height="90" as="geometry" />
        </mxCell>
        <mxCell id="apply_base" value="res = res + t * firstDeltaY" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="278.75" y="1334" width="242.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="loop_k" value="k = 2, n - 1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
          <mxGeometry x="316" y="1454" width="168" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_fwd_loop" value="useForward == true" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="277.5" y="1574" width="244.99999999999997" height="72" as="geometry" />
        </mxCell>
        <mxCell id="calc_term_fwd" value="term = gaussFirstTerm(t, k)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="133.75" y="1706" width="242.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="calc_term_bwd" value="term = gaussSecondTerm(t, k)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="416.25" y="1706" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="check_even_fwd" value="k % 2 == 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="184" y="1826" width="196" height="72" as="geometry" />
        </mxCell>
        <mxCell id="check_even_bwd" value="k % 2 == 0" style="rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="420" y="1826" width="196" height="72" as="geometry" />
        </mxCell>
        <mxCell id="set_offset_fwd_even" value="offset = k / 2" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="5" y="1958" width="145" height="60" as="geometry" />
        </mxCell>
        <mxCell id="set_offset_fwd_odd" value="offset = (k - 1) / 2" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="210" y="1958" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="set_offset_bwd_even" value="offset = k / 2" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="414" y="1958" width="145" height="60" as="geometry" />
        </mxCell>
        <mxCell id="set_offset_bwd_odd" value="offset = (k + 1) / 2" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="605" y="1958" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="calc_deltaY" value="deltaY = diffs&lt;sub&gt;k&lt;/sub&gt;&lt;sub&gt;centerIdx - offset&lt;/sub&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="233.75" y="2078" width="332.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="calc_fact" value="fact = factorial(k)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" parent="1" vertex="1">
          <mxGeometry x="308.75" y="2198" width="182.5" height="60" as="geometry" />
        </mxCell>
        <mxCell id="apply_term" value="res = res + (term * deltaY) / fact" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="252.5" y="2318" width="295" height="60" as="geometry" />
        </mxCell>
        <mxCell id="out_res" value="res" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;" parent="1" vertex="1">
