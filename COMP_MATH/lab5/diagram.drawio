        <mxCell id="new_loop" value="k = 1, n - 1" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="630" y="840" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="new_calc" value="dt = (fwd ? t - (k-1) : t + (k-1))&lt;br&gt;dy = (fwd ? d[k][0] : d[k][n-1-k])&lt;br&gt;term = term * dt&lt;br&gt;res = res + (term * dy) / factorial(k)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="930" width="280" height="90" as="geometry" />
