        <mxCell id="new_cond" value="|x - x&lt;sub&gt;0&lt;/sub&gt;| &lt;= |x - x&lt;sub&gt;n-1&lt;/sub&gt;|" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
