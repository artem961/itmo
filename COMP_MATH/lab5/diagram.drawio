        <mxCell id="new_fwd" value="t = (x - x&lt;sub&gt;0&lt;/sub&gt;) / h&lt;br&gt;res = y&lt;sub&gt;0&lt;/sub&gt;&lt;br&gt;fwd = true" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="660" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="new_bwd" value="t = (x - x&lt;sub&gt;n-1&lt;/sub&gt;) / h&lt;br&gt;res = y&lt;sub&gt;n-1&lt;/sub&gt;&lt;br&gt;fwd = false" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="660" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="SeZBY3181p9hstLFeavz-13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="new_init" target="new_loop">
