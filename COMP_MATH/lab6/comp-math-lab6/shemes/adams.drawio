        <mxCell id="act_copy" value="xs&lt;sub&gt;k&lt;/sub&gt; = starterXs&lt;sub&gt;k&lt;/sub&gt;&lt;br&gt;ys&lt;sub&gt;k&lt;/sub&gt; = starterYs&lt;sub&gt;k&lt;/sub&gt;&lt;br&gt;fs&lt;sub&gt;k&lt;/sub&gt; = f(xs&lt;sub&gt;k&lt;/sub&gt;, ys&lt;sub&gt;k&lt;/sub&gt;)&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
