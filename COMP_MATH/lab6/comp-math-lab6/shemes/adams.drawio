        <mxCell id="act_pred_ab4" value="yPred = ys&lt;sub&gt;i&lt;/sub&gt; + h / 24.0 * (55.0 * fs&lt;sub&gt;i&lt;/sub&gt; - 59.0 * fs&lt;sub&gt;i-1&lt;/sub&gt; + 37.0 * fs&lt;sub&gt;i-2&lt;/sub&gt; - 9.0 * fs&lt;sub&gt;i-3&lt;/sub&gt;)" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
